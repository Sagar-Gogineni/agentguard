# Azure OpenAI credentials
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4

# OpenAI credentials (for Moderation API classifier — free)
OPENAI_API_KEY=your-openai-api-key

# ── Assessment Funnel Web App ────────────────────────────────────
# Set these in Railway dashboard (Settings > Variables) for production

# Required
DB_PATH=./data/assessments.db

# Email delivery (sign up at resend.com, free for 100 emails/day)
# 1. Create account at resend.com
# 2. Add domain navario.tech (they give you DNS records to add)
# 3. Verify domain, then get API key
RESEND_API_KEY=
FROM_EMAIL=agentguard-eu <reports@navario.tech>

# Analytics (optional, skip for now)
# Plausible ($9/mo) or GoatCounter (free) or skip entirely
PLAUSIBLE_DOMAIN=
